# Environment variables for local development of the Dagster + Postgres + Superset stack

# Possibility to pass an own preferred database and user name for the analytics database.
CDS_ANALYTICS_DB_NAME=analytics
CDS_ANALYTICS_DB_USER=analytics

# Database names and users
CDS_DAGSTER_DB_NAME=dagster
CDS_DAGSTER_DB_USER=dagster

CDS_SUPERSET_DB_NAME=superset
CDS_SUPERSET_DB_USER=superset

# Database passwords
CDS_ANALYTICS_DB_PASSWORD=analytics-dev-password
CDS_DAGSTER_DB_PASSWORD=dagster-dev-password
CDS_SUPERSET_DB_PASSWORD=superset-dev-password

# Superset
CDS_SUPERSET_SECRET_KEY=change-me-to-a-long-random-string
CDS_SUPERSET_ADMIN_PASSWORD=change-me

# Optional future values
# CDS_DAGSTER_HOME=/opt/dagster/dagster_home


